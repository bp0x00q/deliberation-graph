{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/deliberation-graph/brief.schema.json",
  "title": "Deliberation brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["problem", "hard_constraints", "success_criteria", "unknowns", "hard_gates", "scoring_dimensions"],
  "properties": {
    "problem": {"type": "string", "minLength": 1},
    "context": {"type": "string"},
    "hard_constraints": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "success_criteria": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "unknowns": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "hard_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"},
          "label": {"type": "string", "minLength": 1}
        }
      }
    },
    "scoring_dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "weight", "direction"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"},
          "label": {"type": "string", "minLength": 1},
          "weight": {"type": "number", "exclusiveMinimum": 0},
          "direction": {"enum": ["maximize", "minimize"]}
        }
      }
    }
  }
}
