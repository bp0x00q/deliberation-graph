{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/deliberation-graph/synthesis.schema.json",
  "title": "Deliberation synthesis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "selected_branch_id", "fallback_branch_id", "rationale",
    "residual_assumptions", "reversal_evidence", "rejected_reasons", "surviving_caveat"
  ],
  "properties": {
    "selected_branch_id": {"type": "string", "pattern": "^branch-[0-9]{3,6}$"},
    "fallback_branch_id": {"type": "string", "pattern": "^branch-[0-9]{3,6}$"},
    "rationale": {"type": "string", "minLength": 1},
    "residual_assumptions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "reversal_evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "rejected_reasons": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1}},
    "surviving_caveat": {"type": "string", "minLength": 1},
    "created_at": {"type": "string"}
  }
}
